<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  System end-of-day pass — Layer 6.
    16:30 ET  reconcile signals / fills / risk / bias and write
              Trading/Ops/System-EOD-{date}.md

  Runs AFTER com.alta.execution_harness (16:05 ET), which needs the SIP quote
  recency window to have passed before it can price the session's fills.

  TRACKED-NOT-LOADED. Operator installs:
    cp scripts/com.alta.system_eod.plist ~/Library/LaunchAgents/
    launchctl load ~/Library/LaunchAgents/com.alta.system_eod.plist
    python3 scripts/plist_watchdog.py --rebaseline "loaded system_eod"
-->
<plist version="1.0">
<dict>
  <key>Label</key><string>com.alta.system_eod</string>
  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/python3</string><string>-m</string><string>execution.eod</string>
  </array>
  <key>WorkingDirectory</key><string>/Users/taboost/quant</string>
  <key>EnvironmentVariables</key><dict>
    <key>PATH</key><string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    <key>PYTHONPATH</key><string>/Users/taboost/quant</string>
  </dict>
  <key>StandardOutPath</key><string>/Users/taboost/quant/logs/system_eod.log</string>
  <key>StandardErrorPath</key><string>/Users/taboost/quant/logs/system_eod.err</string>
  <key>Nice</key><integer>5</integer>
  <key>RunAtLoad</key><false/>
  <key>StartCalendarInterval</key>
  <array>
    <dict><key>Hour</key><integer>16</integer><key>Minute</key><integer>30</integer><key>Weekday</key><integer>1</integer></dict>
    <dict><key>Hour</key><integer>16</integer><key>Minute</key><integer>30</integer><key>Weekday</key><integer>2</integer></dict>
    <dict><key>Hour</key><integer>16</integer><key>Minute</key><integer>30</integer><key>Weekday</key><integer>3</integer></dict>
    <dict><key>Hour</key><integer>16</integer><key>Minute</key><integer>30</integer><key>Weekday</key><integer>4</integer></dict>
    <dict><key>Hour</key><integer>16</integer><key>Minute</key><integer>30</integer><key>Weekday</key><integer>5</integer></dict>
  </array>
</dict>
</plist>
