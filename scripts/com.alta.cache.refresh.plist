<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key><string>com.alta.cache.refresh</string>
    <!-- Refreshes the Reddit sentiment + macro snapshot caches hourly. These used to be refreshed
         by agent_scheduler, which was deprecated/unloaded — leaving the caches to go stale (reddit
         ~13d, macro ~25h) and trip the health check. This narrow job restores just that cadence.
         RunAtLoad fires once immediately. `launchctl load` to enable. -->
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/python3</string>
        <string>/Users/taboost/quant/scripts/refresh_caches.py</string>
    </array>
    <key>WorkingDirectory</key><string>/Users/taboost/quant</string>
    <key>StartInterval</key><integer>3600</integer>
    <key>RunAtLoad</key><true/>
    <key>StandardOutPath</key><string>/Users/taboost/quant/logs/cache_refresh.log</string>
    <key>StandardErrorPath</key><string>/Users/taboost/quant/logs/cache_refresh.err</string>
    <key>EnvironmentVariables</key><dict><key>PATH</key><string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string></dict>
</dict>
</plist>
