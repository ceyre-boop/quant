<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.alta.evening_prep</string>

    <key>Program</key>
    <string>/bin/bash</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/taboost/quant/scripts/evening_prep.sh</string>
    </array>

    <key>StartCalendarInterval</key>
