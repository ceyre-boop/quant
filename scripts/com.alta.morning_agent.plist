<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Autonomous morning agent — Claude reads AGENT_DIRECTIVE.md and executes
  the 08:00 ET routine: information layer pull, Oracle bias, gapper scan,
  GO/NO-GO list, prop sim dashboard update.

  Fires 07:55 ET Mon–Fri (5 min head-start before the 08:00 routine begins).
  launchd uses the machine's LOCAL timezone (America/New_York), so these
  times ARE ET and DST is handled automatically.

  INSTALL (operator hand):
    cp scripts/com.alta.morning_agent.plist ~/Library/LaunchAgents/
    launchctl load ~/Library/LaunchAgents/com.alta.morning_agent.plist
    python3 scripts/plist_watchdog.py --rebaseline "loaded morning_agent"
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.alta.morning_agent</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/sh</string>
    <string>-c</string>
    <string>set -a; . /Users/taboost/quant/.env; set +a; /Users/taboost/.local/bin/claude --print "Read ~/quant/AGENT_DIRECTIVE.md and execute the 08:00 morning routine" --allowedTools "Bash,Read,Write,Edit,Glob,Grep" 2>&amp;1</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/taboost/quant</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    <key>PYTHONPATH</key>
    <string>/Users/taboost/quant</string>
    <key>HOME</key>
    <string>/Users/taboost</string>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/taboost/quant/logs/morning_agent.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/taboost/quant/logs/morning_agent.log</string>

  <key>Nice</key>
  <integer>5</integer>

  <key>RunAtLoad</key>
  <false/>

  <key>StartCalendarInterval</key>
  <array>
    <dict><key>Hour</key><integer>7</integer><key>Minute</key><integer>55</integer><key>Weekday</key><integer>1</integer></dict>
    <dict><key>Hour</key><integer>7</integer><key>Minute</key><integer>55</integer><key>Weekday</key><integer>2</integer></dict>
    <dict><key>Hour</key><integer>7</integer><key>Minute</key><integer>55</integer><key>Weekday</key><integer>3</integer></dict>
    <dict><key>Hour</key><integer>7</integer><key>Minute</key><integer>55</integer><key>Weekday</key><integer>4</integer></dict>
    <dict><key>Hour</key><integer>7</integer><key>Minute</key><integer>55</integer><key>Weekday</key><integer>5</integer></dict>
  </array>
</dict>
</plist>
