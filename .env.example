# CLAWD Quant Trading Configuration
# Copy to  and fill in your values

# Paths
WORKING_DIR=C:\Users\Admin\clawd\02-Trading
DATA_DIR=./data
LOG_DIR=./logs
CSV_EXPORT_DIR=./csv_exports

# Trading Parameters
STARTING_EQUITY=100000
RISK_PER_TRADE=0.02
MAX_POSITIONS=5

# Data Feeds - Alpaca (Primary for paper trading)
# Get keys from: https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=PK7BYJSRVIBLRC2RV6NY7RCAA2
ALPACA_SECRET_KEY=ZND4tvXX6A6uHVYSU87w1wfxg3sYnTSGxQiYgk6jZuw
ALPACA_PAPER=true
https://paper-api.alpaca.markets/v2

# Data Feeds - Polygon (Optional, for more symbols)
POLYGON_API_KEY=

# Server Settings
BACKEND_PORT=8081
HEALTH_PORT=8082
DASHBOARD_PORT=8080

# Symbols
DEFAULT_SYMBOL=SPY
WATCHLIST_SYMBOLS=SPY,QQQ,IWM,DIA,VTI,GLD,SLV,USO,UNG,TLT,LQD,HYG,VIXY,UVXY,SQQQ,SPXL,AAPL,MSFT,AMZN,GOOGL,META,TSLA,NVDA

# Feature Flags
USE_POLYGON=false
USE_ALPACA=true
USE_YFINANCE=true
PAPER_TRADING=true

# Data Settings
DEFAULT_TIMEFRAME=1H
DEFAULT_HISTORY_DAYS=90
MAX_HISTORY_DAYS=1825

# Logging
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=30

# COT/GEX Data (Commercial feeds)
COT_DATA_PATH=./data/cot
GEX_DATA_PATH=./data/gex
USE_COMMERCIAL_COT=false
USE_COMMERCIAL_GEX=false

# ── Tradovate (CME futures execution — MNQ/MES micros) ────────────────────────
# Open a free DEMO account at tradovate.com and register an API app for these.
# Default host is DEMO; set TRADOVATE_LIVE=1 ONLY to use real money.
# NOTE: sovereign/execution/tradovate_bridge.py is UNTESTED until these are filled in.
TRADOVATE_USERNAME=
TRADOVATE_PASSWORD=
TRADOVATE_APP_ID=
TRADOVATE_APP_VERSION=1.0
TRADOVATE_CID=
TRADOVATE_SEC=
TRADOVATE_ACCOUNT_ID=
TRADOVATE_ACCOUNT_SPEC=
# TRADOVATE_LIVE=1

# ── TradingAgents / Ollama (Narrative Advisory Layer) ─────────────────────────
# Local Ollama server — must be running: `ollama serve`
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# Qwen model to use — pull with: `ollama pull qwen3:latest`
OLLAMA_MODEL=qwen3:latest
# Disable the narrative advisory if Ollama is not running (default: true)
ENABLE_NARRATIVE_ADVISORY=true

# ── ThetaData (VRP iron-condor backtest — historical SPY option chains) ────────
# Options Value tier (~$40/mo). Auth is via the local ThetaTerminal gateway login,
# not a URL key; ThetaTerminal exposes a local REST API (default 127.0.0.1:25510).
# sovereign/research/vrp/data_loader.py::ThetaDataLoader is STUBBED until the schema is
# verified live — run `python3 scripts/vrp_schema_verify.py` once after activation.
THETADATA_API_KEY=
THETADATA_BASE_URL=http://127.0.0.1:25510
