# CLAWD Quant Trading Configuration
# Copy to .env and fill in your values

# Paths
WORKING_DIR=C:\Users\Admin\clawd\02-Trading
DATA_DIR=./data
LOG_DIR=./logs
CSV_EXPORT_DIR=./csv_exports

# Trading Parameters
STARTING_EQUITY=100000
RISK_PER_TRADE=0.02
MAX_POSITIONS=5

# Data Feeds - Alpaca (Primary for paper trading)
# Get keys from: https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=PK...
ALPACA_SECRET_KEY=PK...
ALPACA_PAPER=true

# Data Feeds - Polygon (Optional, for more symbols)
POLYGON_API_KEY=

# Server Settings
BACKEND_PORT=8081
HEALTH_PORT=8082
DASHBOARD_PORT=8080

# Symbols
DEFAULT_SYMBOL=SPY
WATCHLIST_SYMBOLS=SPY,QQQ,IWM,DIA,VTI,GLD,SLV,USO,UNG,TLT,LQD,HYG,VIXY,UVXY,SQQQ,SPXL,AAPL,MSFT,AMZN,GOOGL,META,TSLA,NVDA

# Feature Flags
USE_POLYGON=false
USE_ALPACA=true
USE_YFINANCE=true
PAPER_TRADING=true

# Data Settings
DEFAULT_TIMEFRAME=1H
DEFAULT_HISTORY_DAYS=90
MAX_HISTORY_DAYS=1825

# Logging
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=30

# COT/GEX Data (Commercial feeds)
COT_DATA_PATH=./data/cot
GEX_DATA_PATH=./data/gex
USE_COMMERCIAL_COT=false
USE_COMMERCIAL_GEX=false
