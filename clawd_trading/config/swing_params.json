{
  "_description": "Swing Prediction Layer Configuration — Monthly Macro Scoring Engine",
  "_version": "1.0.0",
  
  "run_schedule": {
    "monthly": true,
    "weekly_rescore": true,
    "monthly_day": 1,
    "weekly_day": "monday"
  },
  
  "symbol_universe": {
    "equities": ["NAS100", "SPY", "QQQ", "IWM", "AAPL", "MSFT", "GOOGL", "AMZN", "TSLA", "NVDA"],
    "forex": ["EURUSD", "GBPUSD", "USDJPY", "AUDUSD", "USDCAD", "USDCHF"],
    "commodities": ["GC", "SI", "CL", "NG", "ZW", "ZC"],
    "crypto": ["BTC", "ETH", "SOL", "AVAX"]
  },
  
  "layer_a_fair_value": {
    "z_score_thresholds": {
      "extreme": 2.5,
      "notable": 2.0,
      "moderate": 1.5
    },
    "equity_weights": {
      "ma200w_deviation": 0.5,
      "fed_model_spread": 0.3,
      "pe_zscore": 0.2
    },
    "forex_weights": {
      "real_rate_differential": 0.6,
      "ppp_deviation": 0.4
    },
    "commodity_weights": {
      "cost_of_production": 0.5,
      "inventory_deviation": 0.5
    },
    "crypto_weights": {
      "mvrv_ratio": 0.4,
      "nvt_ratio": 0.3,
      "price_vs_realized": 0.3
    }
  },
  
  "layer_b_positioning": {
    "cot_index": {
      "extreme_long": 90,
      "extreme_short": 10,
      "notable_long": 80,
      "notable_short": 20
    },
    "put_call_ratio": {
      "extreme_bullish": 0.7,
      "extreme_bearish": 1.3,
      "threshold": 1.0
    },
    "options_skew": {
      "extreme_fear": 1.25,
      "extreme_greed": 0.85
    },
    "fear_greed": {
      "extreme_fear": 20,
      "extreme_greed": 80
    },
    "weights": {
      "cot_index": 0.4,
      "put_call": 0.25,
      "options_skew": 0.2,
      "fear_greed": 0.15
    }
  },
  
  "layer_c_regime": {
    "hurst_exponent": {
      "mean_reverting_threshold": 0.45,
      "trending_threshold": 0.55,
      "random_walk_range": [0.48, 0.52]
    },
    "adx": {
      "strong_trend": 25,
      "weak_trend": 20
    },
    "volatility_percentile": {
      "low": 30,
      "high": 70
    },
    "regime_scores": {
      "mean_reverting": 1.0,
      "random_walk": 0.0,
      "trending": -1.0
    }
  },
  
  "layer_d_options": {
    "gex": {
      "extreme_negative": -1.0,
      "extreme_positive": 1.0,
      "notable_threshold": 0.5
    },
    "vix_term_structure": {
      "extreme_backwardation": -0.15,
      "backwardation": -0.05,
      "contango_normal": 0.05,
      "steep_contango": 0.15
    },
    "iv_rank": {
      "expensive": 80,
      "cheap": 20
    },
    "iv_rv_spread": {
      "overpriced": 0.15,
      "fair": 0.05,
      "underpriced": -0.05
    },
    "weights": {
      "gex": 0.35,
      "vix_term": 0.25,
      "iv_rank": 0.25,
      "iv_rv_spread": 0.15
    }
  },
  
  "layer_e_timing": {
    "opex": {
      "week_before_score": -0.5,
      "week_of_score": 0.0,
      "week_after_score": 1.0,
      "neutral_score": 0.0
    },
    "fomc": {
      "two_weeks_before": -0.5,
      "one_week_before": -1.0,
      "week_of": -0.5,
      "week_after": 1.0,
      "neutral": 0.0
    },
    "quarter_end": {
      "last_two_weeks": -0.5,
      "last_week": -1.0,
      "first_week_new": 0.5,
      "neutral": 0.0
    },
    "earnings": {
      "pre_season": -0.3,
      "active": 0.0,
      "post_season": 0.3,
      "neutral": 0.0
    },
    "weights": {
      "opex": 0.35,
      "fomc": 0.35,
      "quarter_end": 0.2,
      "earnings": 0.1
    }
  },
  
  "composite_scoring": {
    "layer_weights": {
      "fair_value": 0.25,
      "positioning": 0.20,
      "regime": 0.20,
      "options": 0.20,
      "timing": 0.15
    },
    "thresholds": {
      "strong_long": 2.5,
      "moderate_long": 1.5,
      "neutral": 0.5,
      "moderate_short": -1.5,
      "strong_short": -2.5
    },
    "min_layers_for_tradeable": 3,
    "min_confidence_for_tradeable": 0.55
  },
  
  "base_rates": {
    "lookback_years": 10,
    "min_occurrences": 10,
    "holding_periods": [20, 40, 60],
    "confidence_thresholds": {
      "high": 0.65,
      "medium": 0.55,
      "low": 0.50
    }
  },
  
  "firebase": {
    "collection_swing_bias": "swing_bias",
    "collection_base_rates": "swing_base_rates",
    "collection_scan_log": "swing_scan_log",
    "ttl_days": 90
  }
}
